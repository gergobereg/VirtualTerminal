+	std::uint32_t VirtualTerminalServer::get_client_vt_command_tx_pgn(std::shared_ptr<ControlFunction> client) const
+	{
+		if (nullptr != client)
+		{
+			auto result = clientVtCommandTxPgnMap.find(client->get_NAME().get_full_name());
+			if (clientVtCommandTxPgnMap.end() != result)
+			{
+				return result->second;
+			}
+		}
+		return static_cast<std::uint32_t>(CANLibParameterGroupNumber::VirtualTerminalToECU);
+	}
+
+	void VirtualTerminalServer::mark_client_uses_swapped_vt_command_pgns(std::shared_ptr<ControlFunction> client)
+	{
+		if (nullptr != client)
+		{
+			const auto clientName = client->get_NAME().get_full_name();
+			auto insertResult = clientVtCommandTxPgnMap.emplace(clientName, static_cast<std::uint32_t>(CANLibParameterGroupNumber::ECUtoVirtualTerminal));
+			if (insertResult.second || (insertResult.first->second != static_cast<std::uint32_t>(CANLibParameterGroupNumber::ECUtoVirtualTerminal)))
+			{
+				insertResult.first->second = static_cast<std::uint32_t>(CANLibParameterGroupNumber::ECUtoVirtualTerminal);
+				LOG_WARNING("[VT Server]: Client %u is using swapped VT command PGNs. Compatibility mode enabled for this client.", client->get_address());
+			}
+		}
+	}
+
+	void VirtualTerminalServer::set_client_vt_command_tx_pgn(std::shared_ptr<ControlFunction> client, std::uint32_t pgn)
+	{
+		if (nullptr != client)
+		{
+			clientVtCommandTxPgnMap[client->get_NAME().get_full_name()] = pgn;
+		}
+	}
+
+	std::uint32_t VirtualTerminalServer::get_vt_command_pgn_for_destination(std::shared_ptr<ControlFunction> destination) const
+	{
+		if (nullptr != destination)
+		{
+			return get_client_vt_command_tx_pgn(destination);
+		}
+		return static_cast<std::uint32_t>(CANLibParameterGroupNumber::VirtualTerminalToECU);
+	}
